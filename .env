# Development: leave commented out — Vite proxy handles /graphql → http://localhost:8080/graphql
# VITE_GRAPHQL_URL=/graphql

# If PDF upload fails with "Missing content type", bypass the proxy and call backend directly:
# VITE_API_URL=http://localhost:8080/api

# Production: set this to your deployed backend URL, e.g.:
# VITE_GRAPHQL_URL=https://api.your-domain.com/graphql
