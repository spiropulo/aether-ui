# Development only: optional overrides (production always uses same-origin /graphql and /api via the UI gateway).
# Default dev: Vite proxy sends /graphql and /api to the backend.
# VITE_GRAPHQL_URL=http://localhost:8080/graphql

# If PDF upload fails with "Missing content type", bypass the proxy and call backend directly:
# VITE_API_URL=http://localhost:8080/api

# Production: set this to your deployed backend URL, e.g.:
# Do not point production builds at a private Cloud Run aether-app URL — IAM returns 403 to browsers.
